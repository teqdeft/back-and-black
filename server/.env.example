# ---- Server ----
PORT=4000
NODE_ENV=development
# In production this MUST be a long random string.
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:5173
PUBLIC_SHOP_URL=https://shop.ashtang.test

# ---- Database ----
# Default is zero-setup SQLite. To use MySQL set DB_CLIENT=mysql2; for
# PostgreSQL set DB_CLIENT=pg, then `npm i mysql2` or `npm i pg` and fill in:
DB_CLIENT=better-sqlite3
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=mlm_hair_oil
