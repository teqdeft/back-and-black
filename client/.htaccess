# ============================================================================
#  Ashtang MLM — frontend (React SPA) .htaccess
#  Place this in the document root that serves the BUILT client:
#  the folder containing index.html and the assets/ folder
#  (e.g. public_html, or your subdomain's docroot).
#
#  Do NOT place this in the Node.js API app folder — cPanel generates that
#  one (with Passenger directives) for you.
# ============================================================================

Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- Force HTTPS (works behind the cPanel proxy too) ---
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # --- Never rewrite API calls: let the Node.js app (mounted at /api) handle them ---
  RewriteRule ^api(/.*)?$ - [L]

  # --- SPA fallback: send everything that is NOT a real file/folder to index.html ---
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# --- Gzip compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript \
    application/javascript application/json image/svg+xml application/xml
</IfModule>

# --- Caching: hashed assets forever, index.html never ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                "access plus 1 year"
  ExpiresByType application/javascript  "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 month"
  ExpiresByType image/png               "access plus 1 month"
  ExpiresByType image/jpeg              "access plus 1 month"
  ExpiresByType font/woff2              "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Long cache for fingerprinted build assets
  <FilesMatch "\.(?:js|css|woff2?|png|jpe?g|svg|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Never cache the HTML entry (so new deploys show up immediately)
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  # Basic security headers for the static site
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Make sure SPA fallback still returns 200 for index.html ---
<IfModule mod_rewrite.c>
  ErrorDocument 404 /index.html
</IfModule>
